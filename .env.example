# Printer Configuration
# USB Vendor ID (hexadecimal)
PRINTER_VENDOR_ID=0x04b8

# USB Product ID (hexadecimal)
PRINTER_PRODUCT_ID=0x0202

# Printer profile (e.g., TM-T88III, TM-T88II, POS-5890)
# See python-escpos documentation for supported profiles
PRINTER_PROFILE=TM-T88III

# USB endpoint (usually 0 for most printers)
PRINTER_IN_EP=0
